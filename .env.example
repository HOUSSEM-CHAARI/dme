# =========================================
# DME Application — Environment Variables
# Copy this file to .env and fill values
# =========================================

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=dme_db
DB_USER=dme_user
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# JWT (use a long random string — min 32 chars)
JWT_SECRET=change-this-to-a-very-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=24h

# URLs
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:3001/api
