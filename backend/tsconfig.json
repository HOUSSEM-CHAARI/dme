{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"],
      "@auth/*": ["./src/auth/*"],
      "@users/*": ["./src/users/*"],
      "@patients/*": ["./src/patients/*"],
      "@doctors/*": ["./src/doctors/*"],
      "@medical-records/*": ["./src/medical-records/*"],
      "@prescriptions/*": ["./src/prescriptions/*"],
      "@analyses/*": ["./src/analyses/*"],
      "@documents/*": ["./src/documents/*"],
      "@reports/*": ["./src/reports/*"],
      "@chronic-diseases/*": ["./src/chronic-diseases/*"],
      "@staff/*": ["./src/staff/*"],
      "@common/*": ["./src/common/*"]
    }
  }
}
